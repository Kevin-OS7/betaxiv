{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/betaxiv/paper-reader/schema/summary.schema.v1.json",
  "title": "Paper Reader Summary",
  "description": "Versioned contract between the paper-summarizer skill (writer) and the Paper Reader VS Code extension (reader). Both sides validate against this file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "paper", "summary", "generatedBy"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Schema contract version. Pinned so reader and writer never silently diverge."
    },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourcePath", "title", "authors", "year", "venue"],
      "properties": {
        "sourcePath": {
          "type": "string",
          "description": "Path to the source PDF, relative to the workspace root (e.g. papers/attention.pdf)."
        },
        "title": { "type": "string" },
        "authors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "year": {
          "type": ["integer", "null"],
          "description": "Publication year, or null if unknown."
        },
        "venue": {
          "type": ["string", "null"],
          "description": "Publication venue, or null if unknown."
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tldr",
        "keyContributions",
        "sections",
        "figures",
        "glossary",
        "openQuestions"
      ],
      "properties": {
        "tldr": {
          "type": "string",
          "description": "One short paragraph capturing the paper at a glance."
        },
        "keyContributions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["heading", "page", "points"],
            "properties": {
              "heading": { "type": "string" },
              "page": {
                "type": ["integer", "null"],
                "minimum": 1,
                "description": "1-based source page anchor. Required key, nullable value. Carried now to enable jump/highlight later without a schema change."
              },
              "points": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "figures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "caption", "page"],
            "properties": {
              "label": { "type": "string", "description": "e.g. Figure 1, Table 2." },
              "caption": { "type": "string" },
              "page": {
                "type": ["integer", "null"],
                "minimum": 1
              }
            }
          }
        },
        "glossary": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "definition"],
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" }
            }
          }
        },
        "openQuestions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "model", "timestamp"],
      "properties": {
        "agent": {
          "type": "string",
          "description": "The agent harness that produced this summary, e.g. Claude Code, Codex, Gemini CLI."
        },
        "model": {
          "type": ["string", "null"],
          "description": "Model identifier if known, else null."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of generation."
        }
      }
    }
  }
}
