{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run BetaXiv Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/extension/dist/**/*.js"],
      "preLaunchTask": "build extension"
    }
  ]
}
