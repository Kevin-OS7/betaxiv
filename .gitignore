# User PDFs and agent-generated summaries stay local (privacy: never leave the machine).
papers/*
!papers/.gitkeep
.betaxiv/summaries/*
!.betaxiv/summaries/.gitkeep

# Highlights + notes are personal reading annotations — stay local (privacy), like summaries.
.betaxiv/annotations/

# Content-id cache (path -> hash) and pre-migration backups: local scratch in this dev repo.
# (In a real library index.json is deterministic and may be committed; here .betaxiv is a
# smoke-test scratch dir, so keep it out of git like the summaries above.)
.betaxiv/index.json
.betaxiv/legacy/

# Extension build artifacts and deps.
extension/node_modules/
extension/dist/
extension/out/
extension/*.vsix
extension/.vscode-test/
extension/.vscode-test.*.json

# Generated webview bundle + vendored PDF.js + bundled skill/schema (copied at build time).
extension/media/webview.js
extension/media/webview.js.map
extension/media/vendor/
extension/assets/

# Locally-installed agent skill copies (canonical source lives in skill/).
.claude/
.agents/
.gemini/

# OS / editor noise
.DS_Store
*.log

# Python artifacts (crop_helper.py / its tests)
__pycache__/
*.pyc
