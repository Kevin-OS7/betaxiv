{
  "name": "betaxiv",
  "displayName": "BetaXiv",
  "description": "Read papers in VS Code: real PDF on the left, an AI-generated structured summary on the right. The summary is produced by your own coding agent (Claude Code / Codex / Gemini CLI) via a bundled Agent Skill. The extension is a pure renderer — it never calls models, touches API keys, or launches agents.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "kevin-os7",
  "icon": "media/betaxiv_logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kevin-OS7/betaxiv.git"
  },
  "bugs": {
    "url": "https://github.com/Kevin-OS7/betaxiv/issues"
  },
  "homepage": "https://github.com/Kevin-OS7/betaxiv#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "pdf",
    "paper",
    "research",
    "summary",
    "arxiv"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "betaxiv.open",
        "title": "Open",
        "category": "BetaXiv",
        "icon": "media/betaxiv_logo.svg"
      },
      {
        "command": "betaxiv.installSkill",
        "title": "Install Skills into Workspace",
        "category": "BetaXiv"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "betaxiv.open",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "betaxiv.open",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test src/test/unit/*.test.ts",
    "compile-tests": "tsc -p tsconfig.test.json",
    "pretest:integration": "npm run build && npm run compile-tests",
    "test:integration": "vscode-test",
    "test": "npm run test:unit && npm run test:integration",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.12",
    "pdfjs-dist": "^4.9.155",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "katex": "^0.16.47",
    "mermaid": "^11.15.0"
  }
}
